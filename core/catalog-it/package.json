{
  "name": "@leanish/catalog-it",
  "version": "0.0.0",
  "private": true,
  "description": "Catalog read-side library for the leanish agent suite. Project shape + Filesystem / S3 / in-memory catalog readers. Consumed by @leanish/runtime and any Layer-3 agent that wants direct catalog access.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "catalogit": "./dist/bin/catalogit.js"
  },
  "files": [
    "dist",
    "!dist/.tsbuildinfo",
    "src"
  ],
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('.tsbuildinfo',{force:true});\"",
    "build": "npm run clean && tsc -b && chmod +x dist/bin/catalogit.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc -b --noEmit && tsc -p tsconfig.test.json --noEmit",
    "check": "npm run typecheck && npm run build && npm test",
    "check:full": "npm run check && npm run test:integration"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@inquirer/prompts": "^8.4.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "^4.1.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
